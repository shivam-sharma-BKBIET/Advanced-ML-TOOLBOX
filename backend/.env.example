# ML Toolbox Environment Variables Example
# Duplicate this file as .env and configure the values for your environment.

# API Configuration
PROJECT_NAME="Multi-Utility Automation & ML Dashboard"
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# Security & Authentication
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET="your-super-secret-jwt-key-change-this"
DATABASE_URL="sqlite:///./ml_toolbox.db"

# Twilio WhatsApp API Settings
# (Leave as ACmock... to run the zero-cost simulator sandbox)
TWILIO_ACCOUNT_SID="ACmockaccountsid1234567890abcdef"
TWILIO_AUTH_TOKEN="mockauthtoken1234567890abcdef"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# SMTP Email Dispatcher Settings
# (Leave username/password as example/mock to run in simulation sandbox)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_FROM_EMAIL="example@gmail.com"
SMTP_USERNAME="example@gmail.com"
SMTP_PASSWORD="mockpassword"

# Google Gemini AI Assistant
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL_NAME="gemini-2.5-flash"
GEMINI_DAILY_GLOBAL_CAP=1200
